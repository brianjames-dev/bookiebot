# Discord
DISCORD_TOKEN=your-discord-bot-token
CHANNEL_NAME=your-discord-channel-name
# Optional: set CHANNEL_ID to enforce by ID instead of name
CHANNEL_ID=your-discord-channel-id
# Comma-separated Discord user IDs allowed to run /debug commands (e.g., 123,456)
DEBUG_ADMINS=

# Optional runtime metadata
BOT_ENV=dev
PUBLIC_BASE_URL=https://your-public-bot-url.example

# GitHub dispatch for Codex autofix
GITHUB_DISPATCH_TOKEN=ghp_example_token_here
GITHUB_REPO=owner/repo-name
GITHUB_DISPATCH_EVENT=codex_autofix

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Google Sheets
# Supply the full JSON for your service account; keep it quoted if it contains whitespace/newlines.
GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "...", "private_key": "...", "client_email": "..."}

# Timezone (optional override)
TZ=America/Los_Angeles

# Subscription pull-date reminders
BOOKIEBOT_SUBSCRIPTION_REMINDERS_ENABLED=true
BOOKIEBOT_SUBSCRIPTION_REMINDER_INTERVAL_SECONDS=3600
BOOKIEBOT_SUBSCRIPTION_REMINDER_SEND_HOUR=10
# Optional per-budget-owner overrides
BRIAN_SUBSCRIPTION_REMINDER_SEND_HOUR=10
HANNAH_SUBSCRIPTION_REMINDER_SEND_HOUR=10

# Plaid webhooks
# For production, use your deployed HTTPS base URL. For local testing, use a tunnel such as:
# cloudflared tunnel --url http://localhost:8080
PLAID_WEBHOOK_SECRET=generate-a-long-random-secret
PLAID_WEBHOOK_URL=https://your-public-bot-url.example/bank/plaid-webhook?secret=generate-a-long-random-secret

# Banking token encryption (required when using Plaid integration)
BANK_TOKEN_ENCRYPTION_KEY=generate-a-long-random-secret
BANK_LINK_SIGNING_SECRET=generate-a-long-random-secret
BANK_DATABASE_URL=
PLAID_CLIENT_ID=
PLAID_SECRET=
